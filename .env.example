# Fusion OLAP Engine - Configuration Template
# Copy to .env and customize for your environment

# Environment (development, staging, production)
FUSION_ENV=development

# Warp API Connection
WARP_URL=http://localhost:8000
WARP_TIMEOUT=30
WARP_MAX_RETRIES=3
WARP_BACKOFF_FACTOR=2

# Server Configuration
FUSION_PORT=9000
FUSION_HOST=0.0.0.0

# DuckDB Configuration
FUSION_MEMORY_LIMIT=4GB
FUSION_THREADS=4
FUSION_DATABASE=:memory:

# Query Cache
FUSION_CACHE_TTL=300
FUSION_CACHE_MAX_ENTRIES=500

# Security (IMPORTANT: Change in production!)
FUSION_API_KEY=
FUSION_CORS_ORIGINS=http://localhost:3000
FUSION_ALLOWED_HOSTS=localhost

# Rate Limiting
FUSION_RATE_LIMIT=100/minute
FUSION_RATE_LIMIT_BURST=20

# Logging
FUSION_LOG_LEVEL=info
FUSION_LOG_FORMAT=text
FUSION_LOG_FILE=

# Circuit Breaker
FUSION_CIRCUIT_BREAKER_THRESHOLD=5
FUSION_CIRCUIT_BREAKER_TIMEOUT=60

# Connection Pool
FUSION_POOL_SIZE=10
FUSION_POOL_MAX_OVERFLOW=5

# Backup
FUSION_BACKUP_ENABLED=false
FUSION_BACKUP_INTERVAL=3600
FUSION_BACKUP_PATH=./data/backups
FUSION_BACKUP_RETENTION_DAYS=7

# External Services (Optional)
# ANTHROPIC_API_KEY=
# PG_HOST=localhost
# PG_DATABASE=myapp
# PG_USER=readonly
# PG_PASSWORD=
